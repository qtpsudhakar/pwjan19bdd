{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "resolveJsonModule": true,
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "features/**/*.ts",
    "pages/**/*.ts",
    "step-definitions/**/*.ts",
    "step-definitions-pom/**/*.ts",
    "support/**/*.ts",
    "reports/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
